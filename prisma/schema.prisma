// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===== Stash schema =====

enum ItemType {
  BOOK
  MOVIE
  SHOW
}

enum ItemStatus {
  WANT
  IN_PROGRESS
  DONE
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  // Stash relations
  items Item[]
  tags  Tag[]

  // Auth.js relations (required by @auth/prisma-adapter)
  accounts Account[]
  sessions Session[]
}

// ===== Auth.js v5 schema (required by @auth/prisma-adapter) =====
//
// We don't use OAuth providers (only magic-link), so most Account fields
// will be null in practice. The model still has to exist because the
// adapter expects it.

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// One row per active session — when you "stay logged in," there's a row here
// keyed by sessionToken stored in your browser cookie.
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Magic-link tokens: one row per "send me a sign-in email" attempt.
// Created when the user submits their email; deleted when they click
// the link (or when expired). This IS the magic link.
model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Item {
  id        String     @id @default(cuid())
  userId    String
  title     String
  type      ItemType
  status    ItemStatus @default(WANT)
  rating    Int?
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags ItemTag[]

  @@index([userId])
}

model Tag {
  id     String @id @default(cuid())
  userId String
  name   String

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ItemTag[]

  @@unique([userId, name])
  @@index([userId])
}

// Join table for many-to-many between Item and Tag.
// Composite PK ensures an item can't be tagged with the same tag twice.
model ItemTag {
  itemId String
  tagId  String

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
  @@index([tagId])
}
