// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===== Auth.js v5 schema (required by @auth/prisma-adapter) =====
//
// Carried over from the Stash project. We don't use OAuth providers
// (only magic-link), so most Account fields will be null in practice.
// The model still has to exist because the adapter expects it.

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts  Account[]
  sessions  Session[]
  favorites UserFavorite[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// One row per active session — when you "stay logged in," there's a row here
// keyed by sessionToken stored in your browser cookie.
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Magic-link tokens: one row per "send me a sign-in email" attempt.
// Created when the user submits their email; deleted when they click
// the link (or when expired). This IS the magic link.
model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ===== NHL Stat Stacker schema =====
//
// Every NHL entity has BOTH our internal `id` (cuid) AND an `externalId`
// from the NHL API. The cuid is our stable identity. The externalId is
// the foreign key into NHL's world — it's how sync runs find existing
// rows for upsert. `@@unique` constraints on externalIds enforce that.

enum Position {
  C   // center
  LW  // left wing
  RW  // right wing
  D   // defense
  G   // goaltender
}

enum GameStatus {
  SCHEDULED
  LIVE
  FINAL
  POSTPONED
}

enum FavoriteKind {
  TEAM
  PLAYER
}

enum SyncKind {
  TEAMS
  ROSTERS
  SCHEDULE
  SCORES
  DAILY
}

enum SyncStatus {
  RUNNING
  SUCCESS
  FAILED
}

model Team {
  id           String   @id @default(cuid())
  externalId   Int      @unique // NHL's team ID (e.g. 1 = NJD)
  abbreviation String   @unique // e.g. "EDM"
  name         String   // e.g. "Edmonton Oilers"
  conference   String?  // e.g. "Western"
  division     String?  // e.g. "Pacific"
  logoUrl      String?
  primaryColor String?  // e.g. "#FF4C00" — for theming

  // Standings (updated by /api/sync/teams). Default 0 so the columns are
  // always populated; sync overwrites with real values.
  gamesPlayed   Int @default(0)
  wins          Int @default(0)
  losses        Int @default(0)
  otLosses      Int @default(0)
  points        Int @default(0)
  goalFor       Int @default(0)
  goalAgainst   Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  players   Player[]
  homeGames Game[]   @relation("HomeTeam")
  awayGames Game[]   @relation("AwayTeam")
}

model Player {
  id           String    @id @default(cuid())
  externalId   Int       @unique // NHL's player ID
  firstName    String
  lastName     String
  fullName     String    // denormalized for ILIKE search
  position     Position
  jerseyNumber Int?      // null = unknown / no number assigned
  headshotUrl  String?

  // Nullable: free agents, injured-reserve, players between teams.
  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seasonStats PlayerSeasonStat[]

  // Indexes that matter for the read-heavy player browser:
  @@index([teamId])         // "roster of team X"
  @@index([fullName])       // ILIKE substring search
  @@index([position])       // filter by position
}

model Season {
  id         String   @id @default(cuid())
  externalId String   @unique // NHL season string e.g. "20242025"
  startDate  DateTime
  endDate    DateTime
  isPlayoffs Boolean  @default(false)

  createdAt DateTime @default(now())

  games       Game[]
  seasonStats PlayerSeasonStat[]
}

model Game {
  id          String     @id @default(cuid())
  externalId  Int        @unique // NHL's gamePk
  seasonId    String
  homeTeamId  String
  awayTeamId  String
  gameTimeUtc DateTime
  status      GameStatus @default(SCHEDULED)
  homeScore   Int?       // null until status leaves SCHEDULED
  awayScore   Int?
  isPlayoff   Boolean    @default(false)
  periodFinal Int?       // 3 (regulation), 4 (OT), 5 (SO)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  homeTeam Team   @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeam Team   @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Restrict)

  @@index([seasonId])
  @@index([gameTimeUtc])         // date-window queries: "games this week"
  @@index([status, gameTimeUtc]) // "live or upcoming"
  @@index([homeTeamId])
  @@index([awayTeamId])
}

model PlayerSeasonStat {
  id       String @id @default(cuid())
  playerId String
  seasonId String

  gamesPlayed         Int @default(0)
  goals               Int @default(0)
  assists             Int @default(0)
  points              Int @default(0)
  plusMinus           Int @default(0)
  pim                 Int @default(0) // penalty minutes
  powerPlayGoals      Int @default(0)
  shorthandedGoals    Int @default(0)
  gameWinningGoals    Int @default(0)
  shots               Int @default(0)
  shootingPctX1000    Int @default(0) // shooting % * 1000 (so 12.3% = 123)

  updatedAt DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  // One stat row per player per season.
  @@unique([playerId, seasonId])
  @@index([seasonId, points]) // leaderboard query: "top point-scorers this season"
}

// One row per sync attempt. Lets us answer "why is the data stale?"
// without needing to read application logs. Captures errors verbatim.
model SyncRun {
  id              String     @id @default(cuid())
  kind            SyncKind
  status          SyncStatus @default(RUNNING)
  startedAt       DateTime   @default(now())
  completedAt    DateTime?
  recordsProcessed Int        @default(0)
  // Stack trace or error message, captured if the sync threw.
  errorMessage   String?    @db.Text

  @@index([kind, startedAt])
  @@index([status, startedAt])
}

// User-saved teams or players. Linked to Auth.js User. Defined here in
// N2 even though the UI lands in N9 — better one migration than two.
model UserFavorite {
  id     String       @id @default(cuid())
  userId String
  kind   FavoriteKind
  // Polymorphic external id. The (kind, externalId) pair points to the
  // corresponding Team.externalId or Player.externalId. We DON'T use a
  // FK here because Prisma doesn't model polymorphic relations cleanly;
  // app code resolves the actual row via two queries.
  externalId Int

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Each (user, kind, externalId) combo is unique — can't favorite the
  // same team twice.
  @@unique([userId, kind, externalId])
  @@index([userId])
}
